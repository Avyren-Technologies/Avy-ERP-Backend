  workingDays           Decimal?   @db.Decimal(5, 1)
  presentDays           Decimal?   @db.Decimal(5, 1)
  lopDays               Decimal?   @db.Decimal(5, 1)
  overtimeHours         Decimal?   @db.Decimal(5, 1)

// Prisma schema for Avy ERP Backend
// Multi-tenant architecture with schema-per-tenant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// PLATFORM MODELS (Shared across all tenants)
// ==========================================

// Tenant Registry - Core tenant information
model Tenant {
  id          String   @id @default(cuid())
  schemaName  String   @unique // PostgreSQL schema name
  companyId   String   @unique
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("tenants")
}

// Company information (platform level)
model Company {
  id          String   @id @default(cuid())
  name        String
  industry    String
  size        CompanySize
  website     String?
  gstNumber   String?  @unique
  address     Json?    // Street, city, state, country, pincode (legacy, use registeredAddress/corporateAddress)
  contactPerson Json?  // Name, email, phone (legacy, use contacts relation)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // === Step 1: Company Identity ===
  displayName       String?
  legalName         String?
  shortName         String?
  businessType      String?
  companyCode       String?  @unique
  cin               String?
  incorporationDate String?
  employeeCount     String?
  emailDomain       String?
  logoUrl           String?

  // === Step 2: Statutory & Tax ===
  pan               String?
  tan               String?
  gstin             String?
  pfRegNo           String?
  esiCode           String?
  ptReg             String?
  lwfrNo            String?
  rocState          String?

  // === Step 3: Address ===
  registeredAddress Json?    // { line1, line2, city, district, state, pin, country, stdCode }
  corporateAddress  Json?    // Same structure, null if sameAsRegistered
  sameAsRegistered  Boolean  @default(true)

  // === Step 4: Fiscal & Calendar ===
  fiscalConfig      Json?    // { fyType, fyCustomStartMonth?, fyCustomEndMonth?, payrollFreq, cutoffDay, disbursementDay, weekStart, timezone, workingDays }

  // === Step 5: Preferences ===
  preferences       Json?    // { currency, language, dateFormat, numberFormat, timeFormat, indiaCompliance, multiCurrency, ess, mobileApp, webApp, systemApp, aiChatbot, eSign, biometric, bankIntegration, emailNotif, whatsapp }
  razorpayConfig    Json?    // { enabled, keyId, keySecret, webhookSecret, accountNumber, autoDisbursement, testMode }

  // === Step 6: Backend Endpoint ===
  endpointType      String   @default("default") // 'default' | 'custom'
  customEndpointUrl String?

  // === Step 7 & 8: Modules & Tier (company-level / common) ===
  multiLocationMode   Boolean @default(false)
  locationConfig      String  @default("common") // 'common' | 'per-location'
  selectedModuleIds   Json?   // string[] of module IDs (used when locationConfig=common)
  customModulePricing Json?   // Record<string, number>
  userTier            String? // starter/growth/scale/enterprise/custom
  customUserLimit     String?
  customTierPrice     String?
  billingType         String? @default("monthly")
  trialDays           Int     @default(0)
  oneTimeMultiplier   Float?
  amcPercentage       Float?

  // === Step 11: Shifts & Time ===
  dayStartTime      String?
  dayEndTime        String?
  weeklyOffs        Json?    // string[] e.g. ["Sunday"]

  // === Step 14: System Controls ===
  systemControls    Json?    // { ncEditMode, loadUnload, cycleTime, payrollLock, leaveCarryForward, overtimeApproval, mfa }

  // === Wizard Status ===
  wizardStatus      String   @default("Draft") // Draft/Pilot/Active/Inactive

  // Relations
  tenant      Tenant?
  users       User[]
  locations   Location[]
  contacts    CompanyContact[]
  shifts      CompanyShift[]
  noSeries    NoSeriesConfig[]
  iotReasons  IotReason[]

  // HRMS Relations
  departments     Department[]
  designations    Designation[]
  grades          Grade[]
  employeeTypes   EmployeeType[]
  costCentres     CostCentre[]
  employees       Employee[]

  @@map("companies")
}

// Platform Users (Super-admins and Company-admins)
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  phone       String?
  role        UserRole @default(COMPANY_ADMIN)
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  resetTokens PasswordResetToken[]
  tenantUsers TenantUser[]

  @@map("users")
}

// Password Reset Tokens
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  code      String    // 6-digit code (hashed with bcrypt)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Tenant-scoped custom roles with permissions
model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  permissions Json     // Array of permission strings e.g. ["hr:view", "hr:create"]
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenantUsers TenantUser[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

// Bridge: User ↔ Tenant ↔ Role
model TenantUser {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  roleId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("tenant_users")
}

// Per-user feature overrides independent of role
model FeatureToggle {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  feature   String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, feature])
  @@index([tenantId])
  @@map("feature_toggles")
}

// Billing and Subscription
model Subscription {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  planId      String
  userTier    UserTier
  billingType        BillingType @default(MONTHLY)
  oneTimeLicenseFee  Float?
  amcAmount          Float?
  amcDueDate         DateTime?
  amcStatus          AmcStatus  @default(NOT_APPLICABLE)
  modules     Json     // Enabled modules with pricing
  status      SubscriptionStatus @default(TRIAL)
  startDate   DateTime @default(now())
  endDate     DateTime?
  trialEndsAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices    Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id          String   @id @default(cuid())
  subscriptionId String
  amount      Float
  status      InvoiceStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Billing enhancement fields
  invoiceNumber      String       @unique @default("")
  invoiceType        InvoiceType  @default(SUBSCRIPTION)
  lineItems          Json         @default("[]")
  subtotal           Float        @default(0)
  cgst               Float        @default(0)
  sgst               Float        @default(0)
  igst               Float        @default(0)
  totalTax           Float        @default(0)
  totalAmount        Float        @default(0)
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  paidVia            PaymentMethod?
  paymentReference   String?
  sentAt             DateTime?
  pdfUrl             String?
  gstNotApplicable   Boolean      @default(false)

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@map("invoices")
}

// Payment records for invoices
model Payment {
  id                   String        @id @default(cuid())
  invoiceId            String
  invoice              Invoice       @relation(fields: [invoiceId], references: [id])
  amount               Float
  method               PaymentMethod
  transactionReference String?
  paidAt               DateTime
  recordedBy           String
  notes                String?
  createdAt            DateTime      @default(now())
  @@map("payments")
}

// Platform-wide billing configuration
model PlatformBillingConfig {
  id                       String   @id @default(cuid())
  defaultOneTimeMultiplier Float    @default(24)
  defaultAmcPercentage     Float    @default(18)
  defaultCgstRate          Float    @default(9)
  defaultSgstRate          Float    @default(9)
  defaultIgstRate          Float    @default(18)
  platformGstin            String?
  invoicePrefix            String   @default("INV")
  nextInvoiceSeq           Int      @default(1)
  updatedAt                DateTime @updatedAt
  @@map("platform_billing_config")
}

// Audit Logs (Platform level)
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String?
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@map("audit_logs")
}

// ==========================================
// TENANT ONBOARDING MODELS
// ==========================================

// Plants & Branches (Step 10)
model Location {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  code                String
  facilityType        String
  customFacilityType  String?
  status              String   @default("Active")
  isHQ                Boolean  @default(false)
  addressLine1        String?
  addressLine2        String?
  city                String?
  district            String?
  state               String?
  pin                 String?
  country             String?  @default("India")
  stdCode             String?
  gstin               String?
  stateGST            String?
  contactName         String?
  contactDesignation  String?
  contactEmail        String?
  contactCountryCode  String?  @default("+91")
  contactPhone        String?
  geoEnabled          Boolean  @default(false)
  geoLocationName     String?
  geoLat              String?
  geoLng              String?
  geoRadius           Int      @default(50)
  geoShape            String?  @default("circle")
  moduleIds           Json?
  customModulePricing Json?
  userTier            String?
  customUserLimit     String?
  customTierPrice     String?
  billingType         String?  @default("monthly")
  trialDays           Int      @default(0)
  oneTimeLicenseFee   Float?
  amcAmount           Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // HRMS Relations
  costCentres     CostCentre[]
  employees       Employee[]

  @@unique([companyId, code])
  @@map("locations")
}

// Key Contacts (Step 9)
model CompanyContact {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  designation String?
  department  String?
  type        String
  email       String
  countryCode String   @default("+91")
  mobile      String
  linkedin    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_contacts")
}

// Shifts (Step 11)
model CompanyShift {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  fromTime      String
  toTime        String
  noShuffle     Boolean  @default(false)
  downtimeSlots Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // HRMS Relations
  employees     Employee[]

  @@map("company_shifts")
}

// Number Series (Step 12)
model NoSeriesConfig {
  id           String   @id @default(cuid())
  companyId    String
  code         String
  linkedScreen String
  description  String?
  prefix       String
  suffix       String?
  numberCount  Int      @default(5)
  startNumber  Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@map("no_series_configs")
}

// IOT Reasons (Step 13)
model IotReason {
  id          String   @id @default(cuid())
  companyId   String
  reasonType  String
  reason      String
  description String?
  department  String?
  planned     Boolean  @default(false)
  duration    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("iot_reasons")
}

// ==========================================
// ENUMS
// ==========================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
  EXPIRED
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
}

enum UserTier {
  STARTER     // 50-100 users
  GROWTH      // 101-200 users
  SCALE       // 201-500 users
  ENTERPRISE  // 501-1000 users
  CUSTOM      // 1000+ users
}

enum BillingType {
  MONTHLY
  ANNUAL
  ONE_TIME_AMC
}

enum InvoiceType {
  SUBSCRIPTION
  ONE_TIME_LICENSE
  AMC
  PRORATED_ADJUSTMENT
}

enum AmcStatus {
  ACTIVE
  OVERDUE
  LAPSED
  NOT_APPLICABLE
}

enum PaymentMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
  RAZORPAY
  UPI
  OTHER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ==========================================
// HRMS ENUMS
// ==========================================

enum EmployeeStatus {
  ACTIVE
  PROBATION
  CONFIRMED
  ON_NOTICE
  SUSPENDED
  EXITED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum JobLevel {
  L1
  L2
  L3
  L4
  L5
  L6
  L7
}

enum WorkType {
  ON_SITE
  REMOTE
  HYBRID
}

enum PaymentMode {
  NEFT
  IMPS
  CHEQUE
}

enum AccountType {
  SAVINGS
  CURRENT
}

enum TimelineEventType {
  JOINED
  PROBATION_STARTED
  CONFIRMED
  PROMOTED
  TRANSFERRED
  SALARY_REVISED
  ONBOARDING_COMPLETE
  RESIGNED
  TERMINATED
  EXITED
  DOCUMENT_UPLOADED
  CUSTOM
}

// ==========================================
// HRMS MODELS — Org Structure
// ==========================================

model Department {
  id               String       @id @default(cuid())
  name             String
  code             String
  parentId         String?
  parent           Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children         Department[] @relation("DepartmentHierarchy")
  headEmployeeId   String?
  costCentreCode   String?
  status           String       @default("Active")
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  designations     Designation[]
  costCentres      CostCentre[]
  employees        Employee[]

  @@unique([companyId, code])
  @@map("departments")
}

model Designation {
  id              String      @id @default(cuid())
  name            String
  code            String
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  gradeId         String?
  grade           Grade?      @relation(fields: [gradeId], references: [id])
  jobLevel        JobLevel?
  managerialFlag  Boolean     @default(false)
  reportsTo       String?
  probationDays   Int?
  status          String      @default("Active")
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  employees       Employee[]

  @@unique([companyId, code])
  @@map("designations")
}

model Grade {
  id              String      @id @default(cuid())
  code            String
  name            String
  ctcMin          Decimal?    @db.Decimal(15, 2)
  ctcMax          Decimal?    @db.Decimal(15, 2)
  hraPercent      Decimal?    @db.Decimal(5, 2)
  pfTier          String?
  benefitFlags    Json?
  probationMonths Int?
  noticeDays      Int?
  status          String      @default("Active")
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  designations    Designation[]
  employees       Employee[]

  @@unique([companyId, code])
  @@map("grades")
}

model EmployeeType {
  id                String   @id @default(cuid())
  name              String
  code              String
  pfApplicable      Boolean  @default(false)
  esiApplicable     Boolean  @default(false)
  ptApplicable      Boolean  @default(false)
  gratuityEligible  Boolean  @default(false)
  bonusEligible     Boolean  @default(false)
  status            String   @default("Active")
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employees         Employee[]

  @@unique([companyId, code])
  @@map("employee_types")
}

model CostCentre {
  id              String      @id @default(cuid())
  code            String
  name            String
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  locationId      String?
  location        Location?   @relation(fields: [locationId], references: [id])
  annualBudget    Decimal?    @db.Decimal(15, 2)
  glAccountCode   String?
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  employees       Employee[]

  @@unique([companyId, code])
  @@map("cost_centres")
}

// ==========================================
// HRMS MODELS — Employee Master
// ==========================================

model Employee {
  id                  String          @id @default(cuid())
  employeeId          String

  // Personal Info (Tab 1)
  firstName           String
  middleName          String?
  lastName            String
  dateOfBirth         DateTime
  gender              Gender
  maritalStatus       MaritalStatus?
  bloodGroup          String?
  fatherMotherName    String?
  nationality         String          @default("Indian")
  religion            String?
  category            String?
  differentlyAbled    Boolean         @default(false)
  disabilityType      String?
  profilePhotoUrl     String?

  // Contact Info
  personalMobile      String
  alternativeMobile   String?
  personalEmail       String
  officialEmail       String?
  currentAddress      Json?
  permanentAddress    Json?
  emergencyContactName     String
  emergencyContactRelation String
  emergencyContactMobile   String

  // Professional Details (Tab 2)
  joiningDate         DateTime
  employeeTypeId      String
  employeeType        EmployeeType    @relation(fields: [employeeTypeId], references: [id])
  departmentId        String
  department          Department      @relation(fields: [departmentId], references: [id])
  designationId       String
  designation         Designation     @relation(fields: [designationId], references: [id])
  gradeId             String?
  grade               Grade?          @relation(fields: [gradeId], references: [id])
  reportingManagerId  String?
  reportingManager    Employee?       @relation("ReportingManager", fields: [reportingManagerId], references: [id])
  reportees           Employee[]      @relation("ReportingManager")
  functionalManagerId String?
  functionalManager   Employee?       @relation("FunctionalManager", fields: [functionalManagerId], references: [id])
  functionalReportees Employee[]      @relation("FunctionalManager")
  workType            WorkType?
  shiftId             String?
  shift               CompanyShift?   @relation(fields: [shiftId], references: [id])
  costCentreId        String?
  costCentre          CostCentre?     @relation(fields: [costCentreId], references: [id])
  locationId          String?
  location            Location?       @relation(fields: [locationId], references: [id])
  noticePeriodDays    Int?
  probationEndDate    DateTime?
  confirmationDate    DateTime?

  // Salary (Tab 3)
  annualCtc           Decimal?        @db.Decimal(15, 2)
  salaryStructure     Json?
  paymentMode         PaymentMode?

  // Bank (Tab 4)
  bankAccountNumber   String?
  bankIfscCode        String?
  bankName            String?
  bankBranch          String?
  accountType         AccountType?

  // Statutory IDs
  panNumber           String?
  aadhaarNumber       String?
  uan                 String?
  esiIpNumber         String?
  passportNumber      String?
  passportExpiry      DateTime?
  drivingLicence      String?
  voterId             String?
  pran                String?

  // Status
  status              EmployeeStatus  @default(PROBATION)
  lastWorkingDate     DateTime?
  exitReason          String?

  // Relations
  companyId           String
  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  nominees            EmployeeNominee[]
  education           EmployeeEducation[]
  previousEmployment  EmployeePrevEmployment[]
  documents           EmployeeDocument[]
  timeline            EmployeeTimeline[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([companyId, employeeId])
  @@map("employees")
}

model EmployeeNominee {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name          String
  relation      String
  dateOfBirth   DateTime?
  sharePercent  Decimal?  @db.Decimal(5, 2)
  aadhaar       String?
  pan           String?
  address       Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("employee_nominees")
}

model EmployeeEducation {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  qualification   String
  degree          String?
  institution     String?
  university      String?
  yearOfPassing   Int?
  marks           String?
  certificateUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("employee_education")
}

model EmployeePrevEmployment {
  id                  String    @id @default(cuid())
  employeeId          String
  employee            Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employerName        String
  designation         String?
  lastCtc             Decimal?  @db.Decimal(15, 2)
  joinDate            DateTime?
  leaveDate           DateTime?
  reason              String?
  experienceLetterUrl String?
  relievingLetterUrl  String?
  previousPfAccount   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("employee_prev_employments")
}

model EmployeeDocument {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documentType    String
  documentNumber  String?
  expiryDate      DateTime?
  fileUrl         String
  fileName        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("employee_documents")
}

model EmployeeTimeline {
  id          String            @id @default(cuid())
  employeeId  String
  employee    Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  eventType   TimelineEventType
  title       String
  description String?
  eventData   Json?
  performedBy String?
  createdAt   DateTime          @default(now())

  @@map("employee_timeline")
}
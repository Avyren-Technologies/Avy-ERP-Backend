  BANK_TRANSFER
  CHEQUE
  CASH
  RAZORPAY
  UPI
  OTHER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}


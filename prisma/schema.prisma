model ApprovalWorkflow {
  id           String   @id @default(cuid())
  name         String
  triggerEvent String // LEAVE_APPLICATION, ATTENDANCE_REGULARIZATION, OVERTIME_CLAIM, REIMBURSEMENT, LOAN_APPLICATION, RESIGNATION, PAYROLL_APPROVAL, SALARY_REVISION, JOB_REQUISITION, BONUS_UPLOAD, LEAVE_OVERRIDE, ASSET_ISSUANCE, EMPLOYEE_TRANSFER, EMPLOYEE_PROMOTION
  steps        Json // Array of { stepOrder, approverRole, approverId?, slaHours, autoEscalate, autoApprove, autoReject }
  isActive     Boolean  @default(true)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requests ApprovalRequest[]

  @@unique([companyId, triggerEvent])
  @@map("approval_workflows")
}

model ApprovalRequest {
  id          String                @id @default(cuid())
  workflowId  String
  workflow    ApprovalWorkflow      @relation(fields: [workflowId], references: [id])
  requesterId String // employeeId or userId who initiated
  entityType  String // "LeaveRequest", "AttendanceOverride", "LoanRecord", etc.
  entityId    String // FK to the actual entity
  currentStep Int                   @default(1)
  status      ApprovalRequestStatus @default(PENDING)
  stepHistory Json? // Array of { step, action, by, at, note }
  data        Json? // Snapshot of request data at time of submission
  companyId   String
  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([companyId, status])
  @@index([companyId, status, entityType])
  @@map("approval_requests")
}

model NotificationTemplate {
  id        String              @id @default(cuid())
  name      String
  subject   String? // For email
  body      String // With tokens: {employee_name}, {leave_days}, {salary_amount}, etc.
  channel   NotificationChannel @default(EMAIL)
  isActive  Boolean             @default(true)
  companyId String
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  rules NotificationRule[]

  @@map("notification_templates")
}

model NotificationRule {
  id            String               @id @default(cuid())
  triggerEvent  String // Same event list as workflows + more: PAYSLIP_PUBLISHED, BIRTHDAY, ANNIVERSARY, etc.
  templateId    String
  template      NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  recipientRole String // EMPLOYEE, MANAGER, HR, FINANCE, IT, ADMIN, ALL
  channel       NotificationChannel  @default(EMAIL)
  isActive      Boolean              @default(true)
  companyId     String
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("notification_rules")
}

model ITDeclaration {
  id               String            @id @default(cuid())
  employeeId       String
  employee         Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  financialYear    String // "2025-26"
  regime           String            @default("NEW") // OLD or NEW
  section80C       Json? // { lic, ppf, elss, nsc, homeLoanPrincipal, schoolFees, total }
  section80CCD     Json? // { npsEmployee, npsAdditional }
  section80D       Json? // { selfPremium, parentPremium, seniorCitizen }
  section80E       Json? // { educationLoanInterest }
  section80G       Json? // { donations }
  section80GG      Json? // { rentPaid }
  section80TTA     Json? // { savingsInterest }
  hraExemption     Json? // { rentPaid, landlordPan, landlordName, cityType }
  ltaExemption     Json? // { travelCost }
  homeLoanInterest Json? // { interestAmount, lenderName, lenderPan }
  otherIncome      Json? // { interestIncome, rentalIncome, otherSources }
  status           DeclarationStatus @default(DRAFT)
  submittedAt      DateTime?
  verifiedBy       String?
  verifiedAt       DateTime?
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([employeeId, financialYear])
  @@map("it_declarations")
}

// ==========================================
// PERFORMANCE MANAGEMENT MODELS
// ==========================================

model AppraisalCycle {
  id                  String               @id @default(cuid())
  name                String
  frequency           String               @default("ANNUAL") // ANNUAL, SEMI_ANNUAL, QUARTERLY
  startDate           DateTime             @db.Date
  endDate             DateTime             @db.Date
  ratingScale         Int                  @default(5) // 1-5 or 1-10
  ratingLabels        Json? // ["Poor","Below","Meets","Exceeds","Exceptional"]
  kraWeightage        Decimal              @default(70) @db.Decimal(5, 2)
  competencyWeightage Decimal              @default(30) @db.Decimal(5, 2)
  bellCurve           Json? // { R1: 5, R2: 15, R3: 60, R4: 15, R5: 5 }
  forcedDistribution  Boolean              @default(false)
  midYearReview       Boolean              @default(false)
  midYearMonth        Int?
  managerEditDays     Int? // days after close managers can revise
  status              AppraisalCycleStatus @default(DRAFT)
  companyId           String
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  goals               Goal[]
  entries             AppraisalEntry[]
  feedback360         Feedback360[]

  @@map("appraisal_cycles")
}

model Goal {
  id            String         @id @default(cuid())
  cycleId       String
  cycle         AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employeeId    String?
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  departmentId  String?
  department    Department?    @relation(fields: [departmentId], references: [id])
  parentGoalId  String?
  parentGoal    Goal?          @relation("GoalCascade", fields: [parentGoalId], references: [id])
  childGoals    Goal[]         @relation("GoalCascade")
  title         String
  description   String?
  kpiMetric     String?
  targetValue   Decimal?       @db.Decimal(10, 2)
  achievedValue Decimal?       @db.Decimal(10, 2)
  weightage     Decimal        @db.Decimal(5, 2)
  level         String         @default("INDIVIDUAL") // COMPANY, DEPARTMENT, INDIVIDUAL
  status        GoalStatus     @default(DRAFT)
  selfRating    Int?
  managerRating Int?
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([cycleId, employeeId])
  @@index([companyId, level])
  @@map("goals")
}

model AppraisalEntry {
  id                   String               @id @default(cuid())
  cycleId              String
  cycle                AppraisalCycle       @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employeeId           String
  employee             Employee             @relation(fields: [employeeId], references: [id])
  selfRating           Decimal?             @db.Decimal(3, 1)
  managerRating        Decimal?             @db.Decimal(3, 1)
  skipLevelRating      Decimal?             @db.Decimal(3, 1)
  finalRating          Decimal?             @db.Decimal(3, 1)
  kraScore             Decimal?             @db.Decimal(5, 2)
  competencyScore      Decimal?             @db.Decimal(5, 2)
  selfComments         String?
  managerComments      String?
  promotionRecommended Boolean              @default(false)
  incrementPercent     Decimal?             @db.Decimal(5, 2)
  status               AppraisalEntryStatus @default(PENDING)
  publishedAt          DateTime?
  companyId            String
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([cycleId, employeeId])
  @@index([cycleId, status])
  @@index([companyId, cycleId])
  @@map("appraisal_entries")
}

model Feedback360 {
  id             String         @id @default(cuid())
  cycleId        String
  cycle          AppraisalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee       @relation("Feedback360Subject", fields: [employeeId], references: [id])
  raterId        String
  rater          Employee       @relation("Feedback360Rater", fields: [raterId], references: [id])
  raterType      RaterType
  ratings        Json // { dimension: score } e.g. { delivery: 4, communication: 3 }
  strengths      String?
  improvements   String?
  wouldWorkAgain Boolean?
  isAnonymous    Boolean        @default(true)
  submittedAt    DateTime?
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([cycleId, employeeId, raterId])
  @@index([cycleId, employeeId])
  @@map("feedback_360")
}

model SkillLibrary {
  id          String         @id @default(cuid())
  name        String
  category    String // Technical, Soft Skills, Compliance, Domain
  description String?
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  mappings    SkillMapping[]

  @@unique([companyId, name])
  @@map("skill_library")
}

model SkillMapping {
  id            String       @id @default(cuid())
  employeeId    String
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skillId       String
  skill         SkillLibrary @relation(fields: [skillId], references: [id], onDelete: Cascade)
  currentLevel  Int          @default(1) // 1-5
  requiredLevel Int          @default(3)
  assessedAt    DateTime?
  assessedBy    String?
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([employeeId, skillId])
  @@map("skill_mappings")
}

model SuccessionPlan {
  id                        String             @id @default(cuid())
  criticalRoleTitle         String
  criticalRoleDesignationId String?
  criticalRoleDesignation   Designation?       @relation(fields: [criticalRoleDesignationId], references: [id])
  successorId               String
  successor                 Employee           @relation(fields: [successorId], references: [id])
  readiness                 SuccessorReadiness @default(NOT_READY)
  developmentPlan           String?
  performanceRating         Decimal?           @db.Decimal(3, 1)
  potentialRating           Decimal?           @db.Decimal(3, 1)
  nineBoxPosition           String? // e.g. "Top Talent", "Future Star", "Core Player"
  companyId                 String
  company                   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@map("succession_plans")
}

// ==========================================
// RECRUITMENT, TRAINING & ADVANCED ENUMS
// ==========================================

enum RequisitionStatus {
  DRAFT
  OPEN
  INTERVIEWING
  OFFERED
  FILLED
  CANCELLED
}

enum CandidateStage {
  APPLIED
  SHORTLISTED
  HR_ROUND
  TECHNICAL
  FINAL
  ASSESSMENT
  OFFER_SENT
  HIRED
  REJECTED
  ON_HOLD
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TrainingMode {
  ONLINE
  CLASSROOM
  WORKSHOP
  EXTERNAL
  BLENDED
  ON_THE_JOB
}

enum TrainingNominationStatus {
  NOMINATED
  ENROLLED
  COMPLETED
  CANCELLED
}

enum AssetCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  DAMAGED
  LOST
}

enum AssetStatus {
  IN_STOCK
  ASSIGNED
  UNDER_REPAIR
  PENDING_RETURN
  RETIRED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum GrievanceStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
  ESCALATED
}

enum DisciplineActionType {
  VERBAL_WARNING
  WRITTEN_WARNING
  SHOW_CAUSE
  PIP
  SUSPENSION
  TERMINATION
}

// ==========================================
// OFFBOARDING & F&F ENUMS
// ==========================================

enum SeparationType {
  VOLUNTARY_RESIGNATION
  RETIREMENT
  TERMINATION_FOR_CAUSE
  LAYOFF_RETRENCHMENT
  DEATH
  ABSCONDING
  CONTRACT_END
}

enum ExitStatus {
  INITIATED
  NOTICE_PERIOD
  CLEARANCE_PENDING
  CLEARANCE_DONE
  FNF_COMPUTED
  FNF_PAID
  COMPLETED
}

enum ClearanceStatus {
  PENDING
  CLEARED
  NOT_APPLICABLE
}

enum FnFStatus {
  DRAFT
  COMPUTED
  APPROVED
  PAID
}

// ==========================================
// RECRUITMENT MODELS
// ==========================================

model JobRequisition {
  id             String            @id @default(cuid())
  title          String
  designationId  String?
  designation    Designation?      @relation("RequisitionDesignation", fields: [designationId], references: [id])
  departmentId   String?
  department     Department?       @relation("RequisitionDepartment", fields: [departmentId], references: [id])
  openings       Int               @default(1)
  description    String?
  budgetMin      Decimal?          @db.Decimal(15, 2)
  budgetMax      Decimal?          @db.Decimal(15, 2)
  targetDate     DateTime?         @db.Date
  sourceChannels Json? // string[]
  status         RequisitionStatus @default(DRAFT)
  approvedBy     String?
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidates     Candidate[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("job_requisitions")
}

model Candidate {
  id            String         @id @default(cuid())
  requisitionId String
  requisition   JobRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  name          String
  email         String
  phone         String?
  source        String? // LinkedIn, Naukri, Referral, Walk-in, Campus
  currentCtc    Decimal?       @db.Decimal(15, 2)
  expectedCtc   Decimal?       @db.Decimal(15, 2)
  resumeUrl     String?
  stage         CandidateStage @default(APPLIED)
  rating        Decimal?       @db.Decimal(3, 1)
  notes         String?
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  interviews    Interview[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("candidates")
}

model Interview {
  id             String          @id @default(cuid())
  candidateId    String
  candidate      Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  round          String // HR_ROUND, TECHNICAL, FINAL, ASSESSMENT
  panelists      Json? // string[] of employee names/ids
  scheduledAt    DateTime
  duration       Int? // minutes
  meetingLink    String?
  feedbackRating Decimal?        @db.Decimal(3, 1)
  feedbackNotes  String?
  status         InterviewStatus @default(SCHEDULED)
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("interviews")
}

// ==========================================
// TRAINING MODELS
// ==========================================

model TrainingCatalogue {
  id                    String               @id @default(cuid())
  name                  String
  type                  String               @default("TECHNICAL") // TECHNICAL, COMPLIANCE, SOFT_SKILLS, ON_THE_JOB, E_LEARNING
  mode                  TrainingMode         @default(CLASSROOM)
  duration              String? // "8 hours", "2 days"
  linkedSkillIds        Json? // string[] -> SkillLibrary ids
  proficiencyGain       Int                  @default(1)
  mandatory             Boolean              @default(false)
  certificationName     String?
  certificationBody     String?
  certificationValidity Int? // years
  vendorProvider        String?
  costPerHead           Decimal?             @db.Decimal(15, 2)
  isActive              Boolean              @default(true)
  companyId             String
  company               Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nominations           TrainingNomination[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@map("training_catalogues")
}

model TrainingNomination {
  id             String                   @id @default(cuid())
  employeeId     String
  employee       Employee                 @relation(fields: [employeeId], references: [id])
  trainingId     String
  training       TrainingCatalogue        @relation(fields: [trainingId], references: [id])
  status         TrainingNominationStatus @default(NOMINATED)
  completionDate DateTime?
  score          Decimal?                 @db.Decimal(5, 2)
  certificateUrl String?
  companyId      String
  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@map("training_nominations")
}

// ==========================================
// ASSET MANAGEMENT MODELS
// ==========================================

model AssetCategory {
  id               String   @id @default(cuid())
  name             String
  depreciationRate Decimal? @db.Decimal(5, 2)
  returnChecklist  Json? // string[]
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets           Asset[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([companyId, name])
  @@map("asset_categories")
}

model Asset {
  id            String            @id @default(cuid())
  name          String
  categoryId    String
  category      AssetCategory     @relation(fields: [categoryId], references: [id])
  serialNumber  String?
  purchaseDate  DateTime?         @db.Date
  purchaseValue Decimal?          @db.Decimal(15, 2)
  condition     AssetCondition    @default(NEW)
  status        AssetStatus       @default(IN_STOCK)
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments   AssetAssignment[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("assets")
}

model AssetAssignment {
  id              String          @id @default(cuid())
  assetId         String
  asset           Asset           @relation(fields: [assetId], references: [id])
  employeeId      String
  employee        Employee        @relation(fields: [employeeId], references: [id])
  issueDate       DateTime        @db.Date
  returnDate      DateTime?       @db.Date
  returnCondition AssetCondition?
  notes           String?
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("asset_assignments")
}

// ==========================================
// EXPENSE, LETTERS, GRIEVANCE & DISCIPLINE MODELS
// ==========================================

model ExpenseClaim {
  id          String      @id @default(cuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  title       String
  amount      Decimal     @db.Decimal(15, 2)
  category    String // TRAVEL, MEDICAL, INTERNET, FUEL, UNIFORM, BUSINESS, OTHER
  receipts    Json? // Array of { fileName, fileUrl }
  description String?
  tripDate    DateTime?   @db.Date
  status      ClaimStatus @default(DRAFT)
  approvedBy  String?
  approvedAt  DateTime?
  paidAt      DateTime?
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("expense_claims")
}

model HRLetterTemplate {
  id           String     @id @default(cuid())
  type         String // OFFER, APPOINTMENT, CONFIRMATION, EXPERIENCE, RELIEVING, PROMOTION, REVISION, TRANSFER, WARNING, SCN, PIP, SUSPENSION, RESIGNATION_ACCEPTANCE
  name         String
  bodyTemplate String     @db.Text // With tokens: {employee_name}, {designation}, etc.
  isActive     Boolean    @default(true)
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  letters      HRLetter[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("hr_letter_templates")
}

model HRLetter {
  id            String           @id @default(cuid())
  templateId    String
  template      HRLetterTemplate @relation(fields: [templateId], references: [id])
  employeeId    String
  employee      Employee         @relation(fields: [employeeId], references: [id])
  effectiveDate DateTime?        @db.Date
  pdfUrl        String?
  eSignStatus       String? // PENDING, SIGNED, DECLINED
  eSignedAt         DateTime?
  eSignToken        String?
  eSignDispatchedAt DateTime?
  companyId         String
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("hr_letters")
}

model GrievanceCategory {
  id             String          @id @default(cuid())
  name           String
  slaHours       Int             @default(72)
  autoEscalateTo String? // role or userId
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cases          GrievanceCase[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([companyId, name])
  @@map("grievance_categories")
}

model GrievanceCase {
  id          String            @id @default(cuid())
  employeeId  String?
  employee    Employee?         @relation(fields: [employeeId], references: [id])
  categoryId  String
  category    GrievanceCategory @relation(fields: [categoryId], references: [id])
  description String
  isAnonymous Boolean           @default(false)
  status      GrievanceStatus   @default(OPEN)
  resolution  String?
  resolvedBy  String?
  resolvedAt  DateTime?
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("grievance_cases")
}

model DisciplinaryAction {
  id            String               @id @default(cuid())
  employeeId    String
  employee      Employee             @relation(fields: [employeeId], references: [id])
  type          DisciplineActionType
  charges       String
  replyDueBy    DateTime?            @db.Date
  replyReceived String?
  pipDuration   Int? // days (for PIP)
  pipOutcome    String? // SUCCESS, PARTIAL, FAILURE
  status        String               @default("ISSUED") // ISSUED, REPLY_RECEIVED, PIP_ACTIVE, RESOLVED, CLOSED
  issuedBy      String?
  companyId     String
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("disciplinary_actions")
}

// ==========================================
// OFFBOARDING & F&F MODELS
// ==========================================

model ExitRequest {
  id                    String          @id @default(cuid())
  employeeId            String
  employee              Employee        @relation(fields: [employeeId], references: [id])
  separationType        SeparationType
  resignationDate       DateTime?       @db.Date
  lastWorkingDate       DateTime?       @db.Date
  noticePeriodDays      Int?
  noticePeriodWaiver    Boolean         @default(false)
  waiverAmount          Decimal?        @db.Decimal(15, 2)
  exitInterviewDone     Boolean         @default(false)
  exitInterviewNotes    String?
  knowledgeTransferDone Boolean         @default(false)
  status                ExitStatus      @default(INITIATED)
  initiatedBy           String? // userId
  companyId             String
  company               Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clearances            ExitClearance[]
  exitInterview         ExitInterview?
  fnfSettlement         FnFSettlement?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@map("exit_requests")
}

model ExitClearance {
  id            String          @id @default(cuid())
  exitRequestId String
  exitRequest   ExitRequest     @relation(fields: [exitRequestId], references: [id], onDelete: Cascade)
  department    String // IT, ADMIN, FINANCE, HR, LIBRARY
  items         Json // Array of { item, status, notes }
  clearedBy     String?
  clearedAt     DateTime?
  status        ClearanceStatus @default(PENDING)
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("exit_clearances")
}

model ExitInterview {
  id             String      @id @default(cuid())
  exitRequestId  String      @unique
  exitRequest    ExitRequest @relation(fields: [exitRequestId], references: [id], onDelete: Cascade)
  responses      Json // Array of { question, answer }
  conductedBy    String?
  conductedAt    DateTime?
  overallRating  Int? // 1-5 experience rating
  wouldRecommend Boolean?
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("exit_interviews")
}

model FnFSettlement {
  id                   String      @id @default(cuid())
  exitRequestId        String      @unique
  exitRequest          ExitRequest @relation(fields: [exitRequestId], references: [id], onDelete: Cascade)
  employeeId           String
  employee             Employee    @relation(fields: [employeeId], references: [id])
  salaryForWorkedDays  Decimal?    @db.Decimal(15, 2)
  leaveEncashment      Decimal?    @db.Decimal(15, 2)
  gratuityAmount       Decimal?    @db.Decimal(15, 2)
  bonusProRata         Decimal?    @db.Decimal(15, 2)
  noticePay            Decimal?    @db.Decimal(15, 2) // positive = company pays, negative = employee owes
  loanRecovery         Decimal?    @db.Decimal(15, 2)
  assetRecovery        Decimal?    @db.Decimal(15, 2)
  reimbursementPending Decimal?    @db.Decimal(15, 2)
  tdsOnFnF             Decimal?    @db.Decimal(15, 2)
  otherDeductions      Decimal?    @db.Decimal(15, 2)
  otherEarnings        Decimal?    @db.Decimal(15, 2)
  totalAmount          Decimal?    @db.Decimal(15, 2)
  components           Json? // Full breakup detail
  status               FnFStatus   @default(DRAFT)
  approvedBy           String?
  approvedAt           DateTime?
  paidAt               DateTime?
  payslipUrl           String?
  settlementLetterUrl  String?
  companyId            String
  company              Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@map("fnf_settlements")
}

// ==========================================
// MANAGER DELEGATION, TRANSFER & PROMOTION
// ==========================================

model ManagerDelegate {
  id         String   @id @default(cuid())
  managerId  String
  manager    Employee @relation("DelegateManager", fields: [managerId], references: [id])
  delegateId String
  delegate   Employee @relation("DelegateProxy", fields: [delegateId], references: [id])
  fromDate   DateTime @db.Date
  toDate     DateTime @db.Date
  isActive   Boolean  @default(true)
  reason     String?
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("manager_delegates")
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  APPLIED
  CANCELLED
}

model EmployeeTransfer {
  id                String         @id @default(cuid())
  employeeId        String
  employee          Employee       @relation(fields: [employeeId], references: [id])
  fromDepartmentId  String?
  fromDepartment    Department?    @relation("TransferFromDept", fields: [fromDepartmentId], references: [id])
  toDepartmentId    String?
  toDepartment      Department?    @relation("TransferToDept", fields: [toDepartmentId], references: [id])
  fromDesignationId String?
  fromDesignation   Designation?   @relation("TransferFromDesig", fields: [fromDesignationId], references: [id])
  toDesignationId   String?
  toDesignation     Designation?   @relation("TransferToDesig", fields: [toDesignationId], references: [id])
  fromLocationId    String?
  fromLocation      Location?      @relation("TransferFromLoc", fields: [fromLocationId], references: [id])
  toLocationId      String?
  toLocation        Location?      @relation("TransferToLoc", fields: [toLocationId], references: [id])
  fromManagerId     String?
  toManagerId       String?
  effectiveDate     DateTime       @db.Date
  reason            String
  transferType      String         @default("LATERAL") // LATERAL, RELOCATION, RESTRUCTURING
  status            TransferStatus @default(REQUESTED)
  approvedBy        String?
  approvedAt        DateTime?
  appliedAt         DateTime?
  transferLetterUrl String?
  companyId         String
  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("employee_transfers")
}

enum PromotionStatus {
  RECOMMENDED
  REQUESTED
  APPROVED
  REJECTED
  APPLIED
  CANCELLED
}

model EmployeePromotion {
  id                 String          @id @default(cuid())
  employeeId         String
  employee           Employee        @relation(fields: [employeeId], references: [id])
  fromDesignationId  String?
  fromDesignation    Designation?    @relation("PromotionFromDesig", fields: [fromDesignationId], references: [id])
  toDesignationId    String
  toDesignation      Designation     @relation("PromotionToDesig", fields: [toDesignationId], references: [id])
  fromGradeId        String?
  fromGrade          Grade?          @relation("PromotionFromGrade", fields: [fromGradeId], references: [id])
  toGradeId          String?
  toGrade            Grade?          @relation("PromotionToGrade", fields: [toGradeId], references: [id])
  currentCtc         Decimal?        @db.Decimal(15, 2)
  newCtc             Decimal?        @db.Decimal(15, 2)
  incrementPercent   Decimal?        @db.Decimal(5, 2)
  effectiveDate      DateTime        @db.Date
  reason             String?
  appraisalEntryId   String? // Link to appraisal where promotionRecommended=true
  status             PromotionStatus @default(REQUESTED)
  approvedBy         String?
  approvedAt         DateTime?
  appliedAt          DateTime?
  promotionLetterUrl String?
  companyId          String
  company            Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@map("employee_promotions")
}

// ── Support Ticket System ──

enum TicketCategory {
  MODULE_CHANGE
  BILLING
  TECHNICAL
  GENERAL
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum SenderRole {
  COMPANY_ADMIN
  SUPER_ADMIN
  SYSTEM
}

model SupportTicket {
  id               String         @id @default(cuid())
  tenantId         String
  companyId        String
  companyName      String
  createdByUserId  String
  createdByName    String
  subject          String
  category         TicketCategory @default(GENERAL)
  priority         TicketPriority @default(NORMAL)
  status           TicketStatus   @default(OPEN)
  assignedToUserId String?
  metadata         Json?
  resolvedAt       DateTime?
  closedAt         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([tenantId])
  @@index([companyId])
  @@index([status])
  @@index([category])
  @@map("support_tickets")
}

model SupportMessage {
  id              String     @id @default(cuid())
  ticketId        String
  senderUserId    String?
  senderName      String
  senderRole      SenderRole @default(COMPANY_ADMIN)
  body            String
  isSystemMessage Boolean    @default(false)
  createdAt       DateTime   @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_messages")
}

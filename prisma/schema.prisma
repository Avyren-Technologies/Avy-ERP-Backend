  NEAREST_15
  NEAREST_30
  FLOOR_15
  CEIL_15
}

enum PunchRounding {
  NONE
  NEAREST_5
  NEAREST_15
}

enum RoundingDirection {
  NEAREST
  UP
  DOWN
}

enum DeductionType {
  NONE
  HALF_DAY_AFTER_LIMIT
  PERCENTAGE
}

enum LocationAccuracy {
  HIGH
  MEDIUM
  LOW
}

enum DeviceType {
  BIOMETRIC
  MOBILE_GPS
  WEB_PORTAL
  SMART_CARD
  FACE_RECOGNITION
}

// ── Overtime ──
enum OTCalculationBasis {
  AFTER_SHIFT
  TOTAL_HOURS

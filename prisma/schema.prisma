// Prisma schema for Avy ERP Backend
// Multi-tenant architecture with schema-per-tenant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// PLATFORM MODELS (Shared across all tenants)
// ==========================================

// Tenant Registry - Core tenant information
model Tenant {
  id         String       @id @default(cuid())
  schemaName String       @unique // PostgreSQL schema name
  companyId  String       @unique
  status     TenantStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // Relations
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("tenants")
}

// Company information (platform level)
model Company {
  id            String      @id @default(cuid())
  name          String
  industry      String
  size          CompanySize
  website       String?
  gstNumber     String?     @unique
  address       Json? // Street, city, state, country, pincode (legacy, use registeredAddress/corporateAddress)
  contactPerson Json? // Name, email, phone (legacy, use contacts relation)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // === Step 1: Company Identity ===
  displayName       String?
  legalName         String?
  shortName         String?
  businessType      String?
  companyCode       String? @unique
  cin               String?
  incorporationDate String?
  employeeCount     String?
  emailDomain       String?
  logoUrl           String?

  // === Step 2: Statutory & Tax ===
  pan      String?
  tan      String?
  gstin    String?
  pfRegNo  String?
  esiCode  String?
  ptReg    String?
  lwfrNo   String?
  rocState String?

  // === Step 3: Address ===
  registeredAddress Json? // { line1, line2, city, district, state, pin, country, stdCode }
  corporateAddress  Json? // Same structure, null if sameAsRegistered
  sameAsRegistered  Boolean @default(true)

  // === Step 4: Fiscal & Calendar ===
  fiscalConfig Json? // { fyType, fyCustomStartMonth?, fyCustomEndMonth?, payrollFreq, cutoffDay, disbursementDay, weekStart, timezone, workingDays }

  // === Step 5: Preferences (typed — see CompanySettings model) ===
  razorpayConfig Json? // { enabled, keyId, keySecret, webhookSecret, accountNumber, autoDisbursement, testMode }

  // === Step 6: Backend Endpoint ===
  endpointType      String  @default("default") // 'default' | 'custom'
  customEndpointUrl String?

  // === Step 7 & 8: Modules & Tier (company-level / common) ===
  multiLocationMode   Boolean @default(false)
  locationConfig      String  @default("common") // 'common' | 'per-location'
  selectedModuleIds   Json? // string[] of module IDs (used when locationConfig=common)
  customModulePricing Json? // Record<string, number>
  userTier            String? // starter/growth/scale/enterprise/custom
  customUserLimit     String?
  customTierPrice     String?
  billingType         String? @default("monthly")
  trialDays           Int     @default(0)
  oneTimeMultiplier   Float?
  amcPercentage       Float?

  // === Step 11: Shifts & Time ===
  dayStartTime String?
  dayEndTime   String?
  weeklyOffs   Json? // string[] e.g. ["Sunday"]

  // === Wizard Status ===
  wizardStatus String @default("Draft") // Draft/Pilot/Active/Inactive

  // Relations
  tenant           Tenant?
  users            User[]
  locations        Location[]
  contacts         CompanyContact[]
  shifts           CompanyShift[]
  noSeries         NoSeriesConfig[]
  iotReasons       IotReason[]
  companySettings  CompanySettings?
  systemControls   SystemControls?
  overtimeRequests OvertimeRequest[]

  // HRMS Relations
  departments   Department[]
  designations  Designation[]
  grades        Grade[]
  employeeTypes EmployeeType[]
  costCentres   CostCentre[]
  employees     Employee[]

  // Attendance & Leave Relations
  attendanceRecords   AttendanceRecord[]
  attendanceOverrides AttendanceOverride[]
  attendanceRule      AttendanceRule?
  holidays            HolidayCalendar[]
  rosters             Roster[]
  overtimeRule        OvertimeRule?
  leaveTypes          LeaveType[]
  leavePolicies       LeavePolicy[]
  leaveBalances       LeaveBalance[]
  leaveRequests       LeaveRequest[]

  // Payroll Relations
  salaryComponents SalaryComponent[]
  salaryStructures SalaryStructure[]
  employeeSalaries EmployeeSalary[]
  pfConfig         PFConfig?
  esiConfig        ESIConfig?
  ptConfigs        PTConfig[]
  gratuityConfig   GratuityConfig?
  bonusConfig      BonusConfig?
  lwfConfigs       LWFConfig[]
  bankConfig       BankConfig?
  loanPolicies     LoanPolicy[]
  loanRecords      LoanRecord[]
  taxConfig        TaxConfig?

  // Payroll Run & Statutory Relations
  payrollRuns      PayrollRun[]
  payrollEntries   PayrollEntry[]
  payslips         Payslip[]
  statutoryFilings StatutoryFiling[]
  salaryHolds      SalaryHold[]
  salaryRevisions  SalaryRevision[]
  arrearEntries    ArrearEntry[]

  // ESS, Approval & Notification Relations
  essConfig             ESSConfig?
  approvalWorkflows     ApprovalWorkflow[]
  approvalRequests      ApprovalRequest[]
  notificationTemplates NotificationTemplate[]
  notificationRules     NotificationRule[]
  itDeclarations        ITDeclaration[]

  // Performance Management Relations
  appraisalCycles  AppraisalCycle[]
  goals            Goal[]
  appraisalEntries AppraisalEntry[]
  feedback360      Feedback360[]
  skillLibrary     SkillLibrary[]
  skillMappings    SkillMapping[]
  successionPlans  SuccessionPlan[]

  // Recruitment Relations
  jobRequisitions JobRequisition[]
  candidates      Candidate[]
  interviews      Interview[]

  // Training Relations
  trainingCatalogues  TrainingCatalogue[]
  trainingNominations TrainingNomination[]

  // Asset Management Relations
  assetCategories  AssetCategory[]
  assets           Asset[]
  assetAssignments AssetAssignment[]

  // Onboarding, Probation & Bonus Batch Relations
  onboardingTemplates OnboardingTemplate[]
  onboardingTasks     OnboardingTask[]
  probationReviews    ProbationReview[]
  bonusBatches        BonusBatch[]
  bonusBatchItems     BonusBatchItem[]

  // Phase 2 Relations
  biometricDevices           BiometricDevice[]
  shiftRotationSchedules     ShiftRotationSchedule[]
  shiftRotationAssignments   ShiftRotationAssignment[]
  productionIncentiveConfigs ProductionIncentiveConfig[]
  productionIncentiveRecords ProductionIncentiveRecord[]
  dataRetentionPolicies      DataRetentionPolicy[]
  dataAccessRequests         DataAccessRequest[]
  consentRecords             ConsentRecord[]
  chatConversations          ChatConversation[]

  // Expense, Letters, Grievance & Discipline Relations
  expenseClaims       ExpenseClaim[]
  hrLetterTemplates   HRLetterTemplate[]
  hrLetters           HRLetter[]
  grievanceCategories GrievanceCategory[]
  grievanceCases      GrievanceCase[]
  disciplinaryActions DisciplinaryAction[]

  // Offboarding & F&F Relations
  exitRequests   ExitRequest[]
  exitClearances ExitClearance[]
  exitInterviews ExitInterview[]
  fnfSettlements FnFSettlement[]

  // Manager Delegation, Transfer & Promotion Relations
  managerDelegates   ManagerDelegate[]
  employeeTransfers  EmployeeTransfer[]
  employeePromotions EmployeePromotion[]

  // Support Ticket Relations
  supportTickets SupportTicket[]

  @@map("companies")
}

// Platform Users (Super-admins and Company-admins)
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      UserRole  @default(COMPANY_ADMIN)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  companyId   String?
  company     Company?             @relation(fields: [companyId], references: [id])
  resetTokens PasswordResetToken[]
  tenantUsers TenantUser[]

  // User ↔ Employee link (ERP industry standard)
  employeeId String?   @unique
  employee   Employee? @relation("UserEmployee", fields: [employeeId], references: [id])

  @@map("users")
}

// Password Reset Tokens
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  code      String // 6-digit code (hashed with bcrypt)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Tenant-scoped custom roles with permissions
model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  permissions Json // Array of permission strings e.g. ["hr:view", "hr:create"]
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenantUsers TenantUser[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

// Bridge: User ↔ Tenant ↔ Role
model TenantUser {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  roleId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("tenant_users")
}

// Billing and Subscription
model Subscription {
  id                String             @id @default(cuid())
  tenantId          String             @unique
  planId            String
  userTier          UserTier
  billingType       BillingType        @default(MONTHLY)
  oneTimeLicenseFee Float?
  amcAmount         Float?
  amcDueDate        DateTime?
  amcStatus         AmcStatus          @default(NOT_APPLICABLE)
  modules           Json // Enabled modules with pricing
  status            SubscriptionStatus @default(TRIAL)
  startDate         DateTime           @default(now())
  endDate           DateTime?
  trialEndsAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String
  amount         Float
  status         InvoiceStatus @default(PENDING)
  dueDate        DateTime
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Billing enhancement fields
  invoiceNumber      String         @unique @default("")
  invoiceType        InvoiceType    @default(SUBSCRIPTION)
  lineItems          Json           @default("[]")
  subtotal           Float          @default(0)
  cgst               Float          @default(0)
  sgst               Float          @default(0)
  igst               Float          @default(0)
  totalTax           Float          @default(0)
  totalAmount        Float          @default(0)
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  paidVia            PaymentMethod?
  paymentReference   String?
  sentAt             DateTime?
  pdfUrl             String?
  gstNotApplicable   Boolean        @default(false)

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@map("invoices")
}

// Payment records for invoices
model Payment {
  id                   String        @id @default(cuid())
  invoiceId            String
  invoice              Invoice       @relation(fields: [invoiceId], references: [id])
  amount               Float
  method               PaymentMethod
  transactionReference String?
  paidAt               DateTime
  recordedBy           String
  notes                String?
  createdAt            DateTime      @default(now())

  @@map("payments")
}

// Platform-wide billing configuration
model PlatformBillingConfig {
  id                       String   @id @default(cuid())
  defaultOneTimeMultiplier Float    @default(24)
  defaultAmcPercentage     Float    @default(18)
  defaultCgstRate          Float    @default(9)
  defaultSgstRate          Float    @default(9)
  defaultIgstRate          Float    @default(18)
  platformGstin            String?
  invoicePrefix            String   @default("INV")
  nextInvoiceSeq           Int      @default(1)
  updatedAt                DateTime @updatedAt

  @@map("platform_billing_config")
}

// Audit Logs (Platform level)
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  userId     String?
  action     String
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  @@map("audit_logs")
}

// ==========================================
// TENANT ONBOARDING MODELS
// ==========================================

// Company Settings — replaces Company.preferences JSON blob
model CompanySettings {
  id        String @id @default(cuid())
  companyId String @unique

  // ── Locale ──
  currency     CurrencyCode @default(INR)
  language     LanguageCode @default(en)
  timezone     String       @default("Asia/Kolkata")
  dateFormat   String       @default("DD/MM/YYYY")
  timeFormat   TimeFormat   @default(TWELVE_HOUR)
  numberFormat String       @default("en-IN")

  // ── Compliance ──
  indiaCompliance Boolean @default(true)
  gdprMode        Boolean @default(false)
  auditTrail      Boolean @default(true)

  // ── Integrations ──
  bankIntegration       Boolean @default(false)
  razorpayEnabled       Boolean @default(false)
  emailNotifications    Boolean @default(true)
  whatsappNotifications Boolean @default(false)
  biometricIntegration  Boolean @default(false)
  eSignIntegration      Boolean @default(false)

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_settings")
}

// System Controls — replaces Company.systemControls JSON blob
model SystemControls {
  id        String @id @default(cuid())
  companyId String @unique

  // ── Module Enablement (replaces Feature Toggles) ──
  attendanceEnabled  Boolean @default(true)
  leaveEnabled       Boolean @default(true)
  payrollEnabled     Boolean @default(true)
  essEnabled         Boolean @default(true)
  performanceEnabled Boolean @default(false)
  recruitmentEnabled Boolean @default(false)
  trainingEnabled    Boolean @default(false)
  mobileAppEnabled   Boolean @default(true)
  aiChatbotEnabled   Boolean @default(false)

  // ── Production Controls ──
  ncEditMode Boolean @default(false)
  loadUnload Boolean @default(false)
  cycleTime  Boolean @default(false)

  // ── Payroll Controls ──
  payrollLock           Boolean @default(true)
  backdatedEntryControl Boolean @default(false)

  // ── Leave Controls ──
  leaveCarryForward   Boolean @default(true)
  compOffEnabled      Boolean @default(false)
  halfDayLeaveEnabled Boolean @default(true)

  // ── Security & Access ──
  mfaRequired                Boolean @default(false)
  sessionTimeoutMinutes      Int     @default(30)
  maxConcurrentSessions      Int     @default(3)
  passwordMinLength          Int     @default(8)
  passwordComplexity         Boolean @default(true)
  accountLockThreshold       Int     @default(5)
  accountLockDurationMinutes Int     @default(30)

  // ── Audit ──
  auditLogRetentionDays Int @default(365)

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_controls")
}

// Plants & Branches (Step 10)
model Location {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  code                String
  facilityType        String
  customFacilityType  String?
  status              String   @default("Active")
  isHQ                Boolean  @default(false)
  addressLine1        String?
  addressLine2        String?
  city                String?
  district            String?
  state               String?
  pin                 String?
  country             String?  @default("India")
  stdCode             String?
  gstin               String?
  stateGST            String?
  contactName         String?
  contactDesignation  String?
  contactEmail        String?
  contactCountryCode  String?  @default("+91")
  contactPhone        String?
  geoEnabled          Boolean  @default(false)
  geoLocationName     String?
  geoLat              String?
  geoLng              String?
  geoRadius           Int      @default(50)
  geoShape            String?  @default("circle")

  // ── Device & Capture Restrictions ──
  allowedDevices      DeviceType[]
  requireSelfie       Boolean? // null = inherit from attendance rules
  requireLiveLocation Boolean? // null = inherit from attendance rules

  // ── Advanced Geo ──
  geoPolygon          Json?    // GeoJSON polygon coordinates for non-circular zones

  moduleIds           Json?
  customModulePricing Json?
  userTier            String?
  customUserLimit     String?
  customTierPrice     String?
  billingType         String?  @default("monthly")
  trialDays           Int      @default(0)
  oneTimeLicenseFee   Float?
  amcAmount           Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // HRMS Relations
  costCentres CostCentre[]
  employees   Employee[]

  // Attendance Relations
  attendanceRecords AttendanceRecord[] @relation("AttendanceLocation")

  // Transfer Relations
  transfersFrom EmployeeTransfer[] @relation("TransferFromLoc")
  transfersTo   EmployeeTransfer[] @relation("TransferToLoc")

  @@unique([companyId, code])
  @@map("locations")
}

// Key Contacts (Step 9)
model CompanyContact {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  designation String?
  department  String?
  type        String
  email       String
  countryCode String   @default("+91")
  mobile      String
  linkedin    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_contacts")
}

// Shifts (Step 11)
model CompanyShift {
  id        String @id @default(cuid())
  companyId String

  // ── Core Timing ──
  name       String
  shiftType  ShiftType @default(DAY)
  startTime  String
  endTime    String
  isCrossDay Boolean   @default(false)

  // ── Policy Overrides (null = inherit from Attendance Rules) ──
  gracePeriodMinutes        Int?
  earlyExitToleranceMinutes Int?
  halfDayThresholdHours     Decimal? @db.Decimal(4, 2)
  fullDayThresholdHours     Decimal? @db.Decimal(4, 2)
  maxLateCheckInMinutes     Int?
  minWorkingHoursForOT      Decimal? @db.Decimal(4, 2)

  // ── Capture Overrides (null = inherit) ──
  requireSelfie  Boolean?
  requireGPS     Boolean?
  allowedSources DeviceType[]

  // ── Behavior ──
  noShuffle           Boolean @default(false)
  autoClockOutMinutes Int?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // HRMS Relations
  employees Employee[]
  breaks    ShiftBreak[]

  // Attendance Relations
  attendanceRecords AttendanceRecord[] @relation("AttendanceShift")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_shifts")
}

model ShiftBreak {
  id      String @id @default(cuid())
  shiftId String

  name      String
  startTime String?
  duration  Int
  type      BreakType
  isPaid    Boolean @default(false)

  shift CompanyShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@map("shift_breaks")
}

// Number Series (Step 12)
model NoSeriesConfig {
  id           String   @id @default(cuid())
  companyId    String
  code         String
  linkedScreen String
  description  String?
  prefix       String
  suffix       String?
  numberCount  Int      @default(5)
  startNumber  Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@map("no_series_configs")
}

// IOT Reasons (Step 13)
model IotReason {
  id          String   @id @default(cuid())
  companyId   String
  reasonType  String
  reason      String
  description String?
  department  String?
  planned     Boolean  @default(false)
  duration    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("iot_reasons")
}

// ==========================================
// ENUMS
// ==========================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
  EXPIRED
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
}

enum UserTier {
  STARTER // 50-100 users
  GROWTH // 101-200 users
  SCALE // 201-500 users
  ENTERPRISE // 501-1000 users
  CUSTOM // 1000+ users
}

enum BillingType {
  MONTHLY
  ANNUAL
  ONE_TIME_AMC
}

enum InvoiceType {
  SUBSCRIPTION
  ONE_TIME_LICENSE
  AMC
  PRORATED_ADJUSTMENT
}

enum AmcStatus {
  ACTIVE
  OVERDUE
  LAPSED
  NOT_APPLICABLE
}


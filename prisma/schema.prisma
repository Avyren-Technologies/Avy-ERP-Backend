// Prisma schema for Avy ERP Backend
// Multi-tenant architecture with schema-per-tenant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// PLATFORM MODELS (Shared across all tenants)
// ==========================================

// Tenant Registry - Core tenant information
model Tenant {
  id          String   @id @default(cuid())
  schemaName  String   @unique // PostgreSQL schema name
  companyId   String   @unique
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("tenants")
}

// Company information (platform level)
model Company {
  id          String   @id @default(cuid())
  name        String
  industry    String
  size        CompanySize
  website     String?
  gstNumber   String?  @unique
  address     Json?    // Street, city, state, country, pincode (legacy, use registeredAddress/corporateAddress)
  contactPerson Json?  // Name, email, phone (legacy, use contacts relation)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // === Step 1: Company Identity ===
  displayName       String?
  legalName         String?
  shortName         String?
  businessType      String?
  companyCode       String?  @unique
  cin               String?
  incorporationDate String?
  employeeCount     String?
  emailDomain       String?
  logoUrl           String?

  // === Step 2: Statutory & Tax ===
  pan               String?
  tan               String?
  gstin             String?
  pfRegNo           String?
  esiCode           String?
  ptReg             String?
  lwfrNo            String?
  rocState          String?

  // === Step 3: Address ===
  registeredAddress Json?    // { line1, line2, city, district, state, pin, country, stdCode }
  corporateAddress  Json?    // Same structure, null if sameAsRegistered
  sameAsRegistered  Boolean  @default(true)

  // === Step 4: Fiscal & Calendar ===
  fiscalConfig      Json?    // { fyType, fyCustomStartMonth?, fyCustomEndMonth?, payrollFreq, cutoffDay, disbursementDay, weekStart, timezone, workingDays }

  // === Step 5: Preferences ===
  preferences       Json?    // { currency, language, dateFormat, numberFormat, timeFormat, indiaCompliance, multiCurrency, ess, mobileApp, webApp, systemApp, aiChatbot, eSign, biometric, bankIntegration, emailNotif, whatsapp }
  razorpayConfig    Json?    // { enabled, keyId, keySecret, webhookSecret, accountNumber, autoDisbursement, testMode }

  // === Step 6: Backend Endpoint ===
  endpointType      String   @default("default") // 'default' | 'custom'
  customEndpointUrl String?

  // === Step 7 & 8: Modules & Tier (company-level / common) ===
  multiLocationMode   Boolean @default(false)
  locationConfig      String  @default("common") // 'common' | 'per-location'
  selectedModuleIds   Json?   // string[] of module IDs (used when locationConfig=common)
  customModulePricing Json?   // Record<string, number>
  userTier            String? // starter/growth/scale/enterprise/custom
  customUserLimit     String?
  customTierPrice     String?
  billingCycle        String? @default("monthly")
  trialDays           Int     @default(0)

  // === Step 11: Shifts & Time ===
  dayStartTime      String?
  dayEndTime        String?
  weeklyOffs        Json?    // string[] e.g. ["Sunday"]

  // === Step 14: System Controls ===
  systemControls    Json?    // { ncEditMode, loadUnload, cycleTime, payrollLock, leaveCarryForward, overtimeApproval, mfa }

  // === Wizard Status ===
  wizardStatus      String   @default("Draft") // Draft/Pilot/Active/Inactive

  // Relations
  tenant      Tenant?
  users       User[]
  locations   Location[]
  contacts    CompanyContact[]
  shifts      CompanyShift[]
  noSeries    NoSeriesConfig[]
  iotReasons  IotReason[]

  @@map("companies")
}

// Platform Users (Super-admins and Company-admins)
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  phone       String?
  role        UserRole @default(COMPANY_ADMIN)
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  resetTokens PasswordResetToken[]
  tenantUsers TenantUser[]

  @@map("users")
}

// Password Reset Tokens
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  code      String    // 6-digit code (hashed with bcrypt)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Tenant-scoped custom roles with permissions
model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  permissions Json     // Array of permission strings e.g. ["hr:view", "hr:create"]
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenantUsers TenantUser[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

// Bridge: User ↔ Tenant ↔ Role
model TenantUser {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  roleId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("tenant_users")
}

// Per-user feature overrides independent of role
model FeatureToggle {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  feature   String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, feature])
  @@index([tenantId])
  @@map("feature_toggles")
}

// Billing and Subscription
model Subscription {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  planId      String
  userTier    UserTier
  billingCycle BillingCycle
  modules     Json     // Enabled modules with pricing
  status      SubscriptionStatus @default(TRIAL)
  startDate   DateTime @default(now())
  endDate     DateTime?
  trialEndsAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices    Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id          String   @id @default(cuid())
  subscriptionId String
  amount      Float
  status      InvoiceStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// Audit Logs (Platform level)
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String?
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@map("audit_logs")
}

// ==========================================
// TENANT ONBOARDING MODELS
// ==========================================

// Plants & Branches (Step 10)
model Location {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  code                String
  facilityType        String
  customFacilityType  String?
  status              String   @default("Active")
  isHQ                Boolean  @default(false)
  addressLine1        String?
  addressLine2        String?
  city                String?
  district            String?
  state               String?
  pin                 String?
  country             String?  @default("India")
  stdCode             String?
  gstin               String?
  stateGST            String?
  contactName         String?
  contactDesignation  String?
  contactEmail        String?
  contactCountryCode  String?  @default("+91")
  contactPhone        String?
  geoEnabled          Boolean  @default(false)
  geoLocationName     String?
  geoLat              String?
  geoLng              String?
  geoRadius           Int      @default(50)
  geoShape            String?  @default("circle")
  moduleIds           Json?
  customModulePricing Json?
  userTier            String?
  customUserLimit     String?
  customTierPrice     String?
  billingCycle        String?  @default("monthly")
  trialDays           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@map("locations")
}

// Key Contacts (Step 9)
model CompanyContact {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  designation String?
  department  String?
  type        String
  email       String
  countryCode String   @default("+91")
  mobile      String
  linkedin    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_contacts")
}

// Shifts (Step 11)
model CompanyShift {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  fromTime      String
  toTime        String
  noShuffle     Boolean  @default(false)
  downtimeSlots Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_shifts")
}

// Number Series (Step 12)
model NoSeriesConfig {
  id           String   @id @default(cuid())
  companyId    String
  code         String
  linkedScreen String
  description  String?
  prefix       String
  suffix       String?
  numberCount  Int      @default(5)
  startNumber  Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@map("no_series_configs")
}

// IOT Reasons (Step 13)
model IotReason {
  id          String   @id @default(cuid())
  companyId   String
  reasonType  String
  reason      String
  description String?
  department  String?
  planned     Boolean  @default(false)
  duration    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("iot_reasons")
}

// ==========================================
// ENUMS
// ==========================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
  EXPIRED
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
}

enum UserTier {
  STARTER     // 50-100 users
  GROWTH      // 101-200 users
  SCALE       // 201-500 users
  ENTERPRISE  // 501-1000 users
  CUSTOM      // 1000+ users
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}
// Prisma schema for Avy ERP Backend
// Multi-tenant architecture with schema-per-tenant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// PLATFORM MODELS (Shared across all tenants)
// ==========================================

// Tenant Registry - Core tenant information
model Tenant {
  id          String   @id @default(cuid())
  schemaName  String   @unique // PostgreSQL schema name
  companyId   String   @unique
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("tenants")
}

// Company information (platform level)
model Company {
  id          String   @id @default(cuid())
  name        String
  industry    String
  size        CompanySize
  website     String?
  gstNumber   String?  @unique
  address     Json     // Street, city, state, country, pincode
  contactPerson Json   // Name, email, phone
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      Tenant?
  users       User[]

  @@map("companies")
}

// Platform Users (Super-admins)
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  phone       String?
  role        UserRole @default(COMPANY_ADMIN)
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])

  @@map("users")
}

// Billing and Subscription
model Subscription {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  planId      String
  userTier    UserTier
  billingCycle BillingCycle
  modules     Json     // Enabled modules with pricing
  status      SubscriptionStatus @default(TRIAL)
  startDate   DateTime @default(now())
  endDate     DateTime?
  trialEndsAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices    Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id          String   @id @default(cuid())
  subscriptionId String
  amount      Float
  status      InvoiceStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// Audit Logs (Platform level)
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String?
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@map("audit_logs")
}

// ==========================================
// ENUMS
// ==========================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
  EXPIRED
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
}

enum UserTier {
  STARTER     // 50-100 users
  GROWTH      // 101-200 users
  SCALE       // 201-500 users
  ENTERPRISE  // 501-1000 users
  CUSTOM      // 1000+ users
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}
// ==========================================
// HRMS MODELS — Org Structure
// ==========================================

model Department {
  id             String       @id @default(cuid())
  name           String
  code           String
  parentId       String?
  parent         Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children       Department[] @relation("DepartmentHierarchy")
  headEmployeeId String?
  costCentreCode String?
  status         String       @default("Active")
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  designations  Designation[]
  costCentres   CostCentre[]
  employees     Employee[]
  goals         Goal[]
  requisitions  JobRequisition[]   @relation("RequisitionDepartment")
  transfersFrom              EmployeeTransfer[]          @relation("TransferFromDept")
  transfersTo                EmployeeTransfer[]          @relation("TransferToDept")
  productionIncentiveConfigs ProductionIncentiveConfig[]

  @@unique([companyId, code])
  @@map("departments")
}

model Designation {
  id             String      @id @default(cuid())
  name           String
  code           String
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  gradeId        String?
  grade          Grade?      @relation(fields: [gradeId], references: [id])
  jobLevel       JobLevel?
  managerialFlag Boolean     @default(false)
  reportsTo      String?
  probationDays  Int?
  status         String      @default("Active")
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  employees       Employee[]
  successionPlans SuccessionPlan[]
  requisitions    JobRequisition[]    @relation("RequisitionDesignation")
  transfersFrom   EmployeeTransfer[]  @relation("TransferFromDesig")
  transfersTo     EmployeeTransfer[]  @relation("TransferToDesig")
  promotionsFrom  EmployeePromotion[] @relation("PromotionFromDesig")
  promotionsTo    EmployeePromotion[] @relation("PromotionToDesig")

  @@unique([companyId, code])
  @@map("designations")
}

model Grade {
  id              String   @id @default(cuid())
  code            String
  name            String
  ctcMin          Decimal? @db.Decimal(15, 2)
  ctcMax          Decimal? @db.Decimal(15, 2)
  hraPercent      Decimal? @db.Decimal(5, 2)
  pfTier          String?
  benefitFlags    Json?
  probationMonths Int?
  noticeDays      Int?
  status          String   @default("Active")
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  designations   Designation[]
  employees      Employee[]
  promotionsFrom EmployeePromotion[] @relation("PromotionFromGrade")
  promotionsTo   EmployeePromotion[] @relation("PromotionToGrade")

  @@unique([companyId, code])
  @@map("grades")
}

model EmployeeType {
  id               String   @id @default(cuid())
  name             String
  code             String
  pfApplicable     Boolean  @default(false)
  esiApplicable    Boolean  @default(false)
  ptApplicable     Boolean  @default(false)
  gratuityEligible Boolean  @default(false)
  bonusEligible    Boolean  @default(false)
  status           String   @default("Active")
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employees Employee[]

  @@unique([companyId, code])
  @@map("employee_types")
}

model CostCentre {
  id            String      @id @default(cuid())
  code          String
  name          String
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  locationId    String?
  location      Location?   @relation(fields: [locationId], references: [id])
  annualBudget  Decimal?    @db.Decimal(15, 2)
  glAccountCode String?
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employees Employee[]

  @@unique([companyId, code])
  @@map("cost_centres")
}

// ==========================================
// HRMS MODELS — Employee Master
// ==========================================

model Employee {
  id         String @id @default(cuid())
  employeeId String

  // Personal Info (Tab 1)
  firstName        String
  middleName       String?
  lastName         String
  dateOfBirth      DateTime
  gender           Gender
  maritalStatus    MaritalStatus?
  bloodGroup       String?
  fatherMotherName String?
  nationality      String         @default("Indian")
  religion         String?
  category         String?
  differentlyAbled Boolean        @default(false)
  disabilityType   String?
  profilePhotoUrl  String?        @db.Text

  // Contact Info
  personalMobile           String
  alternativeMobile        String?
  personalEmail            String
  officialEmail            String?
  currentAddress           Json?
  permanentAddress         Json?
  emergencyContactName     String
  emergencyContactRelation String
  emergencyContactMobile   String

  // Professional Details (Tab 2)
  joiningDate         DateTime
  employeeTypeId      String
  employeeType        EmployeeType  @relation(fields: [employeeTypeId], references: [id])
  departmentId        String
  department          Department    @relation(fields: [departmentId], references: [id])
  designationId       String
  designation         Designation   @relation(fields: [designationId], references: [id])
  gradeId             String?
  grade               Grade?        @relation(fields: [gradeId], references: [id])
  reportingManagerId  String?
  reportingManager    Employee?     @relation("ReportingManager", fields: [reportingManagerId], references: [id])
  reportees           Employee[]    @relation("ReportingManager")
  functionalManagerId String?
  functionalManager   Employee?     @relation("FunctionalManager", fields: [functionalManagerId], references: [id])
  functionalReportees Employee[]    @relation("FunctionalManager")
  workType            WorkType?
  shiftId             String?
  shift               CompanyShift? @relation(fields: [shiftId], references: [id])
  costCentreId        String?
  costCentre          CostCentre?   @relation(fields: [costCentreId], references: [id])
  locationId          String?
  location            Location?     @relation(fields: [locationId], references: [id])
  noticePeriodDays    Int?
  probationEndDate    DateTime?
  confirmationDate    DateTime?

  // Salary (Tab 3)
  annualCtc       Decimal?     @db.Decimal(15, 2)
  salaryStructure Json?
  paymentMode     PaymentMode?

  // Bank (Tab 4)
  bankAccountNumber String?
  bankIfscCode      String?
  bankName          String?
  bankBranch        String?
  accountType       AccountType?

  // Statutory IDs
  panNumber      String?
  aadhaarNumber  String?
  uan            String?
  esiIpNumber    String?
  passportNumber String?
  passportExpiry DateTime?
  drivingLicence String?
  voterId        String?
  pran           String?

  // Status
  status          EmployeeStatus @default(PROBATION)
  lastWorkingDate DateTime?
  exitReason      String?

  // Relations
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // User ↔ Employee link (ERP industry standard)
  user User? @relation("UserEmployee")

  nominees           EmployeeNominee[]
  education          EmployeeEducation[]
  previousEmployment EmployeePrevEmployment[]
  documents          EmployeeDocument[]
  timeline           EmployeeTimeline[]

  // Attendance & Leave Relations
  attendanceRecords AttendanceRecord[]
  overtimeRequests  OvertimeRequest[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]

  // Payroll Relations
  salaryRecords EmployeeSalary[]
  loans         LoanRecord[]

  // Payroll Run & Statutory Relations
  payrollEntries  PayrollEntry[]
  payslips        Payslip[]
  salaryHolds     SalaryHold[]
  salaryRevisions SalaryRevision[]
  arrearEntries   ArrearEntry[]

  // ESS Relations
  itDeclarations ITDeclaration[]

  // Performance Management Relations
  goals                Goal[]
  appraisalEntries     AppraisalEntry[]
  feedback360AsSubject Feedback360[]    @relation("Feedback360Subject")
  feedback360AsRater   Feedback360[]    @relation("Feedback360Rater")
  skillMappings        SkillMapping[]
  successionPlans      SuccessionPlan[]

  // Recruitment, Training, Asset, Expense, Letters, Grievance & Discipline Relations
  trainingNominations TrainingNomination[]
  assetAssignments    AssetAssignment[]
  expenseClaims       ExpenseClaim[]
  hrLetters           HRLetter[]
  grievanceCases      GrievanceCase[]
  disciplinaryActions DisciplinaryAction[]

  // Onboarding, Probation & Bonus Relations
  onboardingTasks  OnboardingTask[]
  probationReviews ProbationReview[]
  bonusBatchItems  BonusBatchItem[]

  // Phase 2 Relations
  shiftRotationAssignments ShiftRotationAssignment[]
  productionIncentives     ProductionIncentiveRecord[]
  dataAccessRequests       DataAccessRequest[]
  consentRecords           ConsentRecord[]
  chatConversations        ChatConversation[]

  // Offboarding & F&F Relations
  exitRequests   ExitRequest[]
  fnfSettlements FnFSettlement[]

  // Manager Delegation, Transfer & Promotion Relations
  delegatesAsManager ManagerDelegate[]   @relation("DelegateManager")
  delegatesAsProxy   ManagerDelegate[]   @relation("DelegateProxy")
  transfers          EmployeeTransfer[]
  promotions         EmployeePromotion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, employeeId])
  @@map("employees")
}

model EmployeeNominee {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name         String
  relation     String
  dateOfBirth  DateTime?
  sharePercent Decimal?  @db.Decimal(5, 2)
  aadhaar      String?
  pan          String?
  address      Json?

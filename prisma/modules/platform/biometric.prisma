// ── Biometric Device Registry (Platform-level) ─────────────────────
// Devices are registered at the platform level because ADMS handshakes
// arrive without any tenant/auth context — only a serial number.

model BiometricDevice {
  id                String    @id @default(cuid())
  serialNumber      String    @unique
  companyId         String?
  locationId        String?
  deviceName        String    @default("Unassigned Device")
  protocol          String    @default("ADMS")
  firmwareVersion   String?
  timezone          String    @default("Asia/Kolkata")

  isActive          Boolean   @default(false)
  lastHeartbeatAt   DateTime?
  heartbeatCount    Int       @default(0)

  claimToken        String?   @unique
  claimStatus       String    @default("UNCLAIMED")
  claimedBy         String?
  claimedAt         DateTime?

  registeredAt      DateTime  @default(now())
  assignedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company?  @relation("CompanyBiometricDevices", fields: [companyId], references: [id], onDelete: SetNull)
  location          Location? @relation("LocationBiometricDevices", fields: [locationId], references: [id], onDelete: SetNull)
  punchLogs         BiometricPunchLog[]

  @@index([companyId])
  @@index([companyId, locationId])
  @@index([claimStatus])
  @@map("biometric_devices")
}

model BiometricPunchLog {
  id                String    @id @default(cuid())
  deviceId          String
  companyId         String?
  serialNumber      String
  deviceUserId      String
  punchTime         DateTime
  statusCode        Int       @default(0)
  verifyType        Int       @default(0)
  rawPayload        String    @db.Text

  dedupeHash        String    @unique

  processingStatus  String    @default("PENDING")
  processedAt       DateTime?
  processingError   String?   @db.Text
  retryCount        Int       @default(0)

  employeeId        String?
  attendanceRecordId String?

  receivedAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())

  device            BiometricDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([companyId, processingStatus])
  @@index([deviceId, deviceUserId])
  @@index([companyId, punchTime])
  @@index([employeeId, punchTime])
  @@index([processingStatus, retryCount])
  @@map("biometric_punch_logs")
}

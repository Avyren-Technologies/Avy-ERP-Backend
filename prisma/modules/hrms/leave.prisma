// ==========================================
// HRMS — Leave Management
// ==========================================
// Models: LeaveType, LeavePolicy, LeaveBalance, LeaveRequest
// Enums: LeaveCategory, AccrualFrequency, LeaveRequestStatus

model LeaveType {
  id                    String            @id @default(cuid())
  name                  String
  code                  String
  category              LeaveCategory     @default(PAID)
  annualEntitlement     Decimal           @db.Decimal(5, 1)
  accrualFrequency      AccrualFrequency? @default(MONTHLY)
  accrualDay            Int? // day of month
  carryForwardAllowed   Boolean           @default(false)
  maxCarryForwardDays   Decimal?          @db.Decimal(5, 1)
  carryForwardExpiry    DateTime?         @db.Date
  encashmentAllowed     Boolean           @default(false)
  maxEncashableDays     Decimal?          @db.Decimal(5, 1)
  encashmentRate        String? // "Basic" or "Gross"
  applicableTypeIds     Json? // string[] of employeeTypeIds
  applicableGender      String? // "All", "Male", "Female"
  probationRestricted   Boolean           @default(false)
  minTenureDays         Int? // min tenure to be eligible
  minAdvanceNotice      Int? // days
  minDaysPerApplication Int?
  maxConsecutiveDays    Int?
  allowHalfDay          Boolean           @default(true)
  weekendSandwich       Boolean           @default(false) // include weekends in leave count
  holidaySandwich       Boolean           @default(false)
  documentRequired      Boolean           @default(false)
  documentAfterDays     Int? // require doc after N days
  lopOnExcess           Boolean           @default(true)
  isActive              Boolean           @default(true)
  companyId             String
  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  minRetainedBalance     Decimal?  @db.Decimal(5, 1)
  maxEncashmentPercent   Int?
  yearEndOnly            Boolean   @default(false)
  carryForwardExpiryDays Int?

  balances LeaveBalance[]
  requests LeaveRequest[]
  policies LeavePolicy[]
  attendanceHalves  AttendanceHalf[]
  encashments            LeaveEncashment[]

  @@unique([companyId, code])
  @@map("leave_types")
}

model LeavePolicy {
  id              String    @id @default(cuid())
  leaveTypeId     String
  leaveType       LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  assignmentLevel String // "company", "department", "designation", "grade", "employeeType", "individual"
  assignmentId    String? // null=company-wide, else FK to the entity
  overrides       Json? // { annualEntitlement, carryForwardDays, etc. }
  priority        Int       @default(0)
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("leave_policies")
}

model LeaveBalance {
  id             String    @id @default(cuid())
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId    String
  leaveType      LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year           Int
  openingBalance Decimal   @default(0) @db.Decimal(5, 1)
  accrued        Decimal   @default(0) @db.Decimal(5, 1)
  taken          Decimal   @default(0) @db.Decimal(5, 1)
  adjusted       Decimal   @default(0) @db.Decimal(5, 1) // manual credits/debits
  booked         Decimal   @default(0) @db.Decimal(5, 1)
  balance        Decimal   @default(0) @db.Decimal(5, 1) // computed: opening + accrued - taken + adjusted
  version        Int       @default(0)
  expiresAt      DateTime? // comp-off expiry date (set via OvertimeRule.compOffExpiryDays)
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions   LeaveBalanceTransaction[]

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id              String             @id @default(cuid())
  referenceNumber String?
  employeeId      String
  employee        Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId     String
  leaveType       LeaveType          @relation(fields: [leaveTypeId], references: [id])
  fromDate        DateTime           @db.Date
  toDate          DateTime           @db.Date
  days            Decimal            @db.Decimal(5, 1)
  isHalfDay       Boolean            @default(false)
  halfDayType     String? // "FIRST_HALF" or "SECOND_HALF"
  reason          String
  status          LeaveRequestStatus @default(PENDING)
  approvedBy      String? // userId
  rejectionNote   String?
  approvedAt      DateTime?
  cancelledAt     DateTime?
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  attendanceHalves  AttendanceHalf[]

  @@map("leave_requests")
}

enum LeaveCategory {
  PAID
  UNPAID
  COMPENSATORY
  STATUTORY
}

enum AccrualFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
  PRO_RATA
  UPFRONT
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  AUTO_APPROVED
}

model LeaveBalanceTransaction {
  id               String                @id @default(cuid())
  sequenceNumber   BigInt                @default(autoincrement())
  leaveBalanceId   String
  leaveBalance     LeaveBalance          @relation(fields: [leaveBalanceId], references: [id], onDelete: Cascade)
  type             LeaveTransactionType
  delta            Decimal               @db.Decimal(5, 1)
  resultingBalance Decimal               @db.Decimal(5, 1)
  beforeState      Json?
  afterState       Json?
  changedBy        String
  reason           String?
  source           String
  referenceId      String?
  referenceType    String?
  idempotencyKey   String?
  metadata         Json?
  companyId        String
  company          Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt        DateTime              @default(now())

  @@index([leaveBalanceId])
  @@index([companyId, type])
  @@index([referenceId, referenceType])
  @@unique([idempotencyKey])
  @@map("leave_balance_transactions")
}

enum LeaveTransactionType {
  INITIALIZED
  ACCRUAL
  ADJUSTMENT
  DIRECT_EDIT
  IMPORT
  CARRY_FORWARD
  ENCASHMENT
  LEAVE_RESERVED
  LEAVE_TAKEN
  LEAVE_CANCELLED
  LEAVE_PARTIAL_CANCEL
  EXPIRED
  AUTO_ADJUSTMENT
  RESERVATION_RELEASED
}

model JobExecution {
  id          String    @id @default(cuid())
  jobType     String
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  periodKey   String
  status      String
  result      Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  error       String?

  @@unique([jobType, companyId, periodKey])
  @@map("job_executions")
}

model LeaveEncashment {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId     String
  leaveType       LeaveType @relation(fields: [leaveTypeId], references: [id])
  year            Int
  days            Decimal   @db.Decimal(5, 1)
  rateBase        String
  perDayAmount    Decimal   @db.Decimal(10, 2)
  totalAmount     Decimal   @db.Decimal(10, 2)
  status          String    @default("PENDING")
  approvedBy      String?
  processedAt     DateTime?
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("leave_encashments")
}

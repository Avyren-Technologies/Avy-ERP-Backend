{
  "name": "avy-erp-backend",
  "version": "1.0.0",
  "description": "Avy ERP Backend - Multi-tenant SaaS ERP Platform",
  "main": "dist/app/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app/server.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prisma:merge": "node scripts/merge-prisma.js",
    "db:generate": "node scripts/merge-prisma.js && prisma generate",
    "db:push": "node scripts/merge-prisma.js && prisma db push",
    "db:migrate": "node scripts/merge-prisma.js && prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "node scripts/merge-prisma.js && prisma studio",
    "worker:reports": "ts-node src/workers/report.worker.ts",
    "worker:analytics": "ts-node src/workers/analytics.worker.ts",
    "worker:notifications": "ts-node src/workers/notification.worker.ts",
    "db:migrate-tenants": "node scripts/merge-prisma.js && prisma migrate deploy && npx tsx scripts/migrate-tenants.ts",
    "company:seed": "npx tsx scripts/seed-company.ts --api-url http://localhost:3030/api/v1 --email superadmin@avyerp.local --password SuperAdmin@12345",
    "demo:seed": "npx tsx scripts/seed-demo-tenant.ts",
    "seed:hrms": "npx tsx scripts/seed-hrms-data.ts"
  },
  "keywords": [
    "erp",
    "saas",
    "multi-tenant",
    "typescript",
    "nodejs",
    "express"
  ],
  "author": "Avyren Technologies",
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-list-endpoints": "^7.1.1",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^13.7.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.2.7",
    "luxon": "^3.7.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "redis": "^4.6.11",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1"
  }
}

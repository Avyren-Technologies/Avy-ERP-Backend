# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/avy_erp?schema=public"
DATABASE_URL_TEMPLATE="postgresql://username:password@localhost:5432/avy_erp?schema={schema}"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_SESSION_DB=2

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Email Configuration (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="noreply@avyerp.com"
FROM_NAME="Avy ERP"

# SMS Configuration (optional)
SMS_API_KEY=""
SMS_API_URL=""

# File Storage Configuration
STORAGE_TYPE="local" # local, s3, azure
STORAGE_LOCAL_PATH="./uploads"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY=""
AWS_SECRET_KEY=""
AWS_REGION="us-east-1"

# Application Configuration
APP_NAME="Avy ERP"
APP_URL="http://localhost:3000"
API_PREFIX="/api/v1"

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX_REQUESTS=5
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=3600000
AUTH_REGISTER_RATE_LIMIT_MAX_REQUESTS=5
AUTH_REFRESH_RATE_LIMIT_WINDOW_MS=900000
AUTH_REFRESH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MS=3600000
AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX_REQUESTS=5

# Logging Configuration
LOG_LEVEL="info"
LOG_FILE_PATH="./logs/app.log"

# Queue Configuration
QUEUE_REMOVE_ON_COMPLETE=50
QUEUE_REMOVE_ON_FAIL=100

# Feature Flags
ENABLE_SWAGGER=false
ENABLE_CORS=true
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://100.121.191.43:5173"

# Multi-tenancy
MAIN_DOMAIN=avyren.in
TENANT_CLIENT_CACHE_SIZE=50
SUPER_ADMIN_EMAIL=admin@avyren.in

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=avy-erp-files
R2_ENDPOINT=
R2_UPLOAD_URL_EXPIRY_SECONDS=300
R2_DOWNLOAD_URL_EXPIRY_SECONDS=3600

# File Upload Limits (bytes)
UPLOAD_MAX_IMAGE_SIZE=5242880
UPLOAD_MAX_DOCUMENT_SIZE=10485760
# Notifications
FIREBASE_SERVICE_ACCOUNT_KEY=
EXPO_ACCESS_TOKEN=
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_DEDUP_TTL_SEC=60
NOTIFICATIONS_IDEMPOTENCY_TTL_SEC=86400
NOTIFICATIONS_BATCH_THRESHOLD=5
NOTIFICATIONS_BATCH_WINDOW_SEC=300
NOTIFICATIONS_MAX_QUEUE_LOW=10000
NOTIFICATIONS_MAX_QUEUE_DEFAULT=50000
NOTIFICATIONS_RECEIPT_POLL_SEC=30
NOTIFICATIONS_RECEIPT_MAX_AGE_MIN=15
NOTIFICATIONS_DLQ_RETENTION_DAYS=7

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Meta Cloud API (WhatsApp)
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_API_VERSION=v21.0

# Notification feature flags + safeguards (Phase 1A)
NOTIFICATIONS_CRON_ENABLED=true
NOTIFICATIONS_SMS_ENABLED=true
NOTIFICATIONS_WHATSAPP_ENABLED=true
NOTIFICATIONS_SMS_DRY_RUN=false
NOTIFICATIONS_WHATSAPP_DRY_RUN=false
NOTIFICATIONS_USER_RATE_LIMIT_PER_MIN=20
NOTIFICATIONS_TENANT_RATE_LIMIT_PER_MIN=1000
NOTIFICATIONS_BULK_CHUNK_SIZE=50
NOTIFICATIONS_BULK_MIN_RECIPIENTS=20
NOTIFICATIONS_BULK_QUEUE_HIGH_WATER=5000
NOTIFICATIONS_CONSENT_CACHE_TTL_SEC=300
NOTIFICATIONS_SMS_DAILY_CAP_PER_TENANT=500
NOTIFICATIONS_SMS_DAILY_CAP_PER_USER=10
NOTIFICATIONS_WHATSAPP_DAILY_CAP_PER_TENANT=500
NOTIFICATIONS_WHATSAPP_DAILY_CAP_PER_USER=10
NOTIFICATIONS_EVENT_RETENTION_DAYS=90
NOTIFICATIONS_CRON_COMPANY_CONCURRENCY=5
NOTIFICATIONS_CRON_JITTER_MS=60000
NOTIFICATIONS_METRICS_ENABLED=true
